# Configurações do Banco de Dados MySQL
DB_HOST=endereco_do_banco_na_nuvem
DB_USER=usuario
DB_PASSWORD=senha
DB_NAME=nome_do_banco
DB_PORT=3306

# Provedor de Storage (Valores aceitos: "gcp" ou "azure")
STORAGE_PROVIDER=gcp

# Configurações Google Cloud Storage (se STORAGE_PROVIDER=gcp)
GCP_PROJECT_ID=meu_projeto_id
GCP_BUCKET_NAME=nome_do_bucket_gcp

# Configurações Azure Blob Storage (se STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=string_de_conexao_aqui
AZURE_CONTAINER_NAME=nome_do_container_azure